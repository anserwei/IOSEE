# ==============================================================================
# IOSEE — .gitignore
# ==============================================================================

# ---- build artifacts --------------------------------------------------------
build/
build_*/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json

# Fortran object / module / archive files (in-tree builds)
*.o
*.mod
*.smod
*.a
*.so
*.so.*
*.dylib

# ---- runtime outputs written by the driver ---------------------------------
# The driver writes NetCDF output files to the current working directory.
# Keep tracked data/ files (LUTs, view-angle tables) but exclude anything
# generated by an IOSEE run.
emissivity_*.nc
emiss_*.nc
/examples/*.nc
/examples/_run_*.config
/examples/effective_view_angle.nc
/examples/iosee
/examples/data

# ---- large data file (distributed via GitHub Release) ----------------------
# See data/README.md for download instructions.
/data/water_optical_constants.nc

# ---- OS / editor state ------------------------------------------------------
.DS_Store
*~
*.swp
*.swo
.vscode/
.idea/

# ---- python caches (from docs generation script) ---------------------------
__pycache__/
*.pyc
